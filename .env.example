# ── Ambiente ────────────────────────────────────────────
NODE_ENV=development
APP_PORT=3000
APP_HOST=0.0.0.0
APP_BASE_URL=http://localhost:3000
WEB_BASE_URL=http://localhost:5173

# ── AutoConf API (obrigatório) ───────────────────────────
AUTOCONF_BASE_URL=https://api.autoconf.com.br
AUTOCONF_AUTH_TOKEN=
AUTOCONF_REVENDA_TOKEN=

# ── Webhook N8N (handoff de leads) ───────────────────────
HANDOFF_WEBHOOK_URL=https://webhook.dexidigital.com.br/webhook/integracao-openai

# ── OAuth 2.1 / JWT (obrigatório em produção) ────────────
# Gere com: openssl rand -base64 48
JWT_SECRET=

# client_id exibido pelo ChatGPT Builder ao registrar a Action
OAUTH_CLIENT_ID=

# redirect_uri gerado pelo ChatGPT Builder (copiar exatamente)
# Exemplo: https://chatgpt.com/connector/oauth/ohId_xxxxx
OAUTH_REDIRECT_URI=

# ── MCP / Auth (opcional) ───────────────────────────────
# Quando true, exige Bearer token mesmo em desenvolvimento
MCP_AUTH_REQUIRED=false

# Registro de API keys para acesso service-to-service
# Formato: "token1:scope1,scope2;token2:scope1"
# MCP_API_KEYS=

# ── Produção (VPS / Docker) ──────────────────────────────
# NODE_ENV=production
# APP_PORT=3001
# APP_HOST=0.0.0.0
# APP_BASE_URL=https://concierge.attraveiculos.com.br
# WEB_BASE_URL=https://attraveiculos.com.br
# AUTOCONF_AUTH_TOKEN=<TOKEN_AUTH_AQUI>
# AUTOCONF_REVENDA_TOKEN=<TOKEN_REVENDA_AQUI>
# HANDOFF_WEBHOOK_URL=https://webhook.dexidigital.com.br/webhook/integracao-openai
# JWT_SECRET=<openssl rand -base64 48>
# OAUTH_CLIENT_ID=<client_id do ChatGPT Builder>
# OAUTH_REDIRECT_URI=https://chatgpt.com/connector/oauth/<id>
# MCP_AUTH_REQUIRED=true
